            "date": 1776566042465,
            "name": "Commit-0",
            "content": "/* =========================================\r\n   ui.js — HTML Injection Layer\r\n   inject ทุก UI section เข้า #app\r\n   ========================================= */\r\n\r\n(function () {\r\n\r\n  /* ---- HEADER ---- */\r\n  const HEADER = `\r\n<header class=\"hdr\">\r\n  <div class=\"logo\" onclick=\"goHome()\">\r\n    <div class=\"logo-wordmark\">\r\n      <span class=\"logo-main\"><span style=\"color:#e50914;\">DRINK</span><span style=\"color:#fff;\">ORDOOM</span></span>\r\n      <span class=\"logo-sub\">ยกหรือยับ</span>\r\n    </div>\r\n  </div>\r\n  <div class=\"hdr-r\">\r\n    <div class=\"user-chip\" id=\"user-chip\" onclick=\"toggleUserDropdown()\">\r\n      <div class=\"chip-av\"><i class=\"fi fi-sr-user\"></i></div>\r\n      <span class=\"chip-name\" id=\"user-display-name\"></span>\r\n      <div class=\"chip-divider\"></div>\r\n      <div class=\"chip-credit\">\r\n        <i class=\"fi fi-sr-coins\" style=\"color:var(--gold);font-size:.75rem;\"></i>\r\n        <span class=\"amt\" id=\"cr-disp\">0</span>\r\n        <span class=\"lbl\">เครดิต</span>\r\n      </div>\r\n      <div class=\"chip-arr\"><i class=\"fi fi-sr-angle-down\"></i></div>\r\n      <div class=\"user-dropdown\">\r\n        <div class=\"dropdown-header\">\r\n          <div class=\"dh-avatar\"><i class=\"fi fi-sr-user\"></i></div>\r\n          <div>\r\n            <div class=\"dh-name\" id=\"dropdown-username\"></div>\r\n            <div class=\"dh-sub\"><span class=\"dh-dot\"></span> ออนไลน์</div>\r\n          </div>\r\n        </div>\r\n        <button class=\"dropdown-item\" onclick=\"event.stopPropagation(); goHome()\">\r\n          <i class=\"fi fi-sr-home\"></i> หน้าหลัก\r\n        </button>\r\n        <button class=\"dropdown-item topup\" onclick=\"event.stopPropagation(); openTopup()\">\r\n          <i class=\"fi fi-sr-coins\"></i> เติมเครดิต\r\n        </button>\r\n        <button class=\"dropdown-item\" onclick=\"event.stopPropagation(); openProfile(); toggleUserDropdown();\">\r\n          <i class=\"fi fi-sr-user\"></i> ประวัติเติมเงิน\r\n        </button>\r\n        <button class=\"dropdown-item\" id=\"btn-admin-dropdown\" style=\"display:none\" onclick=\"event.stopPropagation(); showAdmin()\">\r\n          <i class=\"fi fi-sr-settings\"></i> จัดการระบบ\r\n        </button>\r\n        <div class=\"dropdown-divider\"></div>\r\n        <button class=\"dropdown-item danger\" onclick=\"event.stopPropagation(); logout()\">\r\n          <i class=\"fi fi-sr-sign-out-alt\"></i> ออกจากระบบ\r\n        </button>\r\n      </div>\r\n    </div>\r\n    <button id=\"btn-login\" onclick=\"openLogin()\"><i class=\"fi fi-sr-user\"></i><span class=\"lbl-txt\">เข้าสู่ระบบ</span></button>\r\n  </div>\r\n</header>`;\r\n\r\n  /* ---- HOME SCREEN ---- */\r\n  const HOME = `\r\n<div id=\"home-screen\">\r\n  <section class=\"hero\">\r\n    <div class=\"big-title\"><div>Drink or Doom</div><div class=\"r\">ยกหรือยับ</div></div>\r\n    <p class=\"hero-sub\">\r\n      <span class=\"chip\"><i class=\"fi fi-sr-layers\" style=\"color:var(--red);font-size:.85rem;\"></i> ถ้านั่งกินเหล้าเหงาๆก็มาเข้าเว็บเราได้นะ</span>\r\n    </p>\r\n    <p class=\"sec-label\">เลือกกองไพ่</p>\r\n    <div class=\"deck-grid-wrap\">\r\n      <div class=\"deck-grid\" id=\"deck-grid\"></div>\r\n      <button class=\"btn-play\" id=\"btn-play\" onclick=\"startGame()\" disabled>\r\n        <i class=\"fi fi-sr-play\"></i> เลือกไพ่แล้วกดเริ่ม\r\n      </button>\r\n    </div>\r\n  </section>\r\n</div>`;\r\n\r\n  /* ---- GAME SCREEN ---- */\r\n  const GAME = `\r\n<div id=\"game-screen\" style=\"display:none\">\r\n  <div class=\"game-hdr\">\r\n    <div style=\"display:flex;align-items:center;gap:14px;\">\r\n      <button class=\"btn-ghost\" onclick=\"goHome()\"><i class=\"fi fi-sr-angle-left\"></i> กลับ</button>\r\n      <div class=\"g-deck-info\">\r\n        <div class=\"g-deck-ico\" id=\"g-ico-wrap\"><i id=\"g-ico\" class=\"fi fi-sr-flame\"></i></div>\r\n        <div>\r\n          <div class=\"g-nm\" id=\"g-nm\"></div>\r\n          <div class=\"g-rm\"><i class=\"fi fi-rr-copy\" style=\"font-size:.7rem;opacity:.5;\"></i><span id=\"g-rm\"></span></div>\r\n        </div>\r\n      </div>\r\n    </div>\r\n    <div style=\"display:flex;align-items:center;gap:10px;\">\r\n      <button class=\"btn-history\" onclick=\"openHistDrawer()\" id=\"btn-history\">\r\n        <i class=\"fi fi-sr-time-past\"></i>\r\n        <span class=\"hist-btn-lbl\">ประวัติ</span>\r\n        <span class=\"hist-badge\" id=\"hist-badge\" style=\"display:none\">0</span>\r\n      </button>\r\n      <div class=\"layout-toggle\">\r\n        <button class=\"lt-btn act\" id=\"lt-scatter\" onclick=\"setLayout('scatter')\" title=\"กระจายเละ\"><i class=\"fi fi-sr-shuffle\"></i></button>\r\n        <button class=\"lt-btn\" id=\"lt-stack\" onclick=\"setLayout('stack')\" title=\"เรียงตับ\"><i class=\"fi fi-sr-layers\"></i></button>\r\n        <button class=\"lt-btn\" id=\"lt-touch\" onclick=\"openTouchPicker()\" title=\"สุ่มผู้เล่น\"><i class=\"fi fi-sr-cursor-finger\"></i></button>\r\n      </div>\r\n      <div class=\"g-layout-label\" id=\"g-layout-label\">เลือกแบบสุ่ม</div>\r\n    </div>\r\n  </div>\r\n  <div class=\"table-area\">\r\n    <div class=\"cards-wrap\" id=\"cards-wrap\"></div>\r\n    <div class=\"cost-hint\">\r\n      <i class=\"fi fi-rr-cursor\" style=\"opacity:.6;\"></i>\r\n      แตะการ์ดเพื่อเปิด · ใช้ <span class=\"hl\" id=\"cost-show\">1</span> เครดิต/ใบ\r\n    </div>\r\n  </div>\r\n  <div id=\"hist-drawer-overlay\" onclick=\"closeHistDrawer()\"></div>\r\n  <div id=\"hist-drawer\">\r\n    <div class=\"hist-drawer-handle\"></div>\r\n    <div class=\"hist-drawer-hdr\">\r\n      <div class=\"hist-drawer-title\">\r\n        <i class=\"fi fi-sr-time-past\" style=\"color:var(--red);\"></i>\r\n        ไพ่ที่เปิดไปแล้ว <span class=\"hist-drawer-count\" id=\"hist-drawer-count\">0</span>\r\n      </div>\r\n      <button class=\"hist-drawer-close\" onclick=\"closeHistDrawer()\"><i class=\"fi fi-sr-cross\"></i></button>\r\n    </div>\r\n    <div class=\"hist-drawer-body\" id=\"hist-drawer-body\">\r\n      <div class=\"hist-empty\"><i class=\"fi fi-sr-layers\"></i> ยังไม่ได้เปิดไพ่ใบไหน</div>\r\n    </div>\r\n  </div>\r\n</div>`;\r\n\r\n  /* ---- ADMIN SCREEN ---- */\r\n  const ADMIN = `\r\n<div id=\"admin-screen\" style=\"display:none\">\r\n  <div class=\"adm-hdr\">\r\n    <div>\r\n      <div class=\"adm-ttl\"><i class=\"fi fi-sr-settings-sliders\" style=\"color:var(--red);\"></i> <span class=\"r\">ADMIN</span> PANEL</div>\r\n      <div class=\"adm-sub\">จัดการไพ่และกองไพ่ทั้งหมด</div>\r\n    </div>\r\n    <button class=\"btn-ghost\" onclick=\"goHome()\"><i class=\"fi fi-sr-home\"></i> หน้าหลัก</button>\r\n  </div>\r\n  <div class=\"stats-bar\">\r\n    <div class=\"stat-card\"><div class=\"stat-label\">ผู้ใช้ทั้งหมด</div><div class=\"stat-val gold\" id=\"stat-users\">0</div><div class=\"stat-sub\">+12 สัปดาห์นี้</div></div>\r\n    <div class=\"stat-card\"><div class=\"stat-label\">ยอดเติมเงิน</div><div class=\"stat-val green\" id=\"stat-revenue\">฿0</div><div class=\"stat-sub\">เดือนนี้</div></div>\r\n    <div class=\"stat-card\"><div class=\"stat-label\">กองไพ่</div><div class=\"stat-val red\" id=\"stat-decks\">0</div><div class=\"stat-sub\">ชุดใช้งานอยู่</div></div>\r\n    <div class=\"stat-card\"><div class=\"stat-label\">ไพ่ทั้งหมด</div><div class=\"stat-val white\" id=\"stat-cards\">0</div><div class=\"stat-sub\">รวมทั้งหมด</div></div>\r\n  </div>\r\n  <div class=\"tabs\">\r\n    <button class=\"tab act\" onclick=\"switchTab('decks',0)\"><i class=\"fi fi-sr-layers\"></i> กองไพ่</button>\r\n    <button class=\"tab\" onclick=\"switchTab('cards',1)\"><i class=\"fi fi-sr-pencil\"></i> แก้ไขไพ่</button>\r\n    <button class=\"tab\" onclick=\"switchTab('users',2)\"><i class=\"fi fi-sr-users\"></i> ผู้ใช้</button>\r\n    <button class=\"tab\" onclick=\"switchTab('stats',3)\"><i class=\"fi fi-sr-chart-histogram\"></i> สถิติ</button>\r\n    <button class=\"tab\" onclick=\"switchTab('history',4)\"><i class=\"fi fi-sr-coins\"></i> ประวัติเครดิต</button>\r\n    <button class=\"tab\" onclick=\"switchTab('announce',5)\"><i class=\"fi fi-sr-bell\"></i> ประกาศ</button>\r\n    <button class=\"tab\" onclick=\"switchTab('settings',6)\"><i class=\"fi fi-sr-settings\"></i> ตั้งค่า</button>\r\n    <button class=\"tab\" onclick=\"switchTab('search',7)\"><i class=\"fi fi-sr-search\"></i> ค้นหาไพ่</button>\r\n  </div>\r\n  <div class=\"tab-content act\" id=\"tc-decks\">\r\n    <div class=\"deck-list-adm\" id=\"adm-deck-list\"></div>\r\n    <button class=\"btn-add\" onclick=\"openDeckForm()\"><i class=\"fi fi-sr-plus\"></i> เพิ่มกองไพ่ใหม่</button>\r\n  </div>\r\n  <div class=\"tab-content\" id=\"tc-cards\">\r\n    <div style=\"display:flex;align-items:center;gap:10px;margin-bottom:16px;\">\r\n      <label style=\"color:var(--text2);font-size:.85rem;display:flex;align-items:center;gap:6px;\"><i class=\"fi fi-sr-layers\"></i> กองไพ่:</label>\r\n      <select class=\"fc\" id=\"adm-deck-sel\" style=\"width:200px\" onchange=\"loadCE()\"></select>\r\n    </div>\r\n    <div class=\"card-editor-box\">\r\n      <h3 id=\"ce-title\"><i class=\"fi fi-sr-layers\" style=\"color:var(--red);\"></i> เลือกกองไพ่ก่อน</h3>\r\n      <div class=\"card-list-ed\" id=\"card-list-ed\"></div>\r\n      <div style=\"display:flex;gap:8px;flex-wrap:wrap;margin-top:10px;\">\r\n        <button class=\"btn-add-card\" onclick=\"addCRow()\"><i class=\"fi fi-sr-plus\"></i> เพิ่ม 1 ใบ</button>\r\n        <button class=\"btn-add-card\" onclick=\"addMultiRows(5)\" style=\"background:rgba(245,197,24,.08);border-color:rgba(245,197,24,.25);color:var(--gold);\"><i class=\"fi fi-sr-apps-add\"></i> เพิ่ม 5 ช่อง</button>\r\n        <button class=\"btn-add-card\" onclick=\"openBulkPaste()\" style=\"background:rgba(229,9,20,.08);border-color:rgba(229,9,20,.3);color:var(--red);\"><i class=\"fi fi-sr-copy-alt\"></i> วางหลายใบ</button>\r\n      </div>\r\n    </div>\r\n    <div style=\"display:flex;justify-content:flex-end;margin-top:14px;\">\r\n      <button class=\"btn-save\" onclick=\"saveCards()\"><i class=\"fi fi-sr-disk\"></i> บันทึก</button>\r\n    </div>\r\n  </div>\r\n  <div class=\"tab-content\" id=\"tc-users\">\r\n    <div id=\"admin-user-list\"><p style=\"color:var(--text3);font-size:.85rem;padding:16px;\">กำลังโหลด...</p></div>\r\n  </div>\r\n  <div class=\"tab-content\" id=\"tc-stats\">\r\n    <p style=\"color:var(--text3);font-size:.85rem;padding:16px;\"><i class=\"fi fi-sr-spinner fi-spin\"></i> กำลังโหลดสถิติ...</p>\r\n  </div>\r\n  <div class=\"tab-content\" id=\"tc-history\">\r\n    <p style=\"color:var(--text3);font-size:.85rem;padding:16px;\">กำลังโหลด...</p>\r\n  </div>\r\n  <div class=\"tab-content\" id=\"tc-announce\">\r\n    <div class=\"sheet-sec\">\r\n      <h3><i class=\"fi fi-sr-bell\" style=\"color:var(--red);\"></i> เพิ่มประกาศใหม่</h3>\r\n      <div class=\"fg\"><label><i class=\"fi fi-sr-text\"></i> หัวข้อ</label><input class=\"fc\" id=\"ann-title\" placeholder=\"หัวข้อประกาศ\"></div>\r\n      <div class=\"fg\"><label><i class=\"fi fi-sr-comment\"></i> ข้อความ</label><textarea class=\"fc\" id=\"ann-message\" rows=\"3\" placeholder=\"รายละเอียด...\"></textarea></div>\r\n      <div class=\"fg\"><label><i class=\"fi fi-sr-tag\"></i> ประเภท</label>\r\n        <select class=\"fc\" id=\"ann-type\">\r\n          <option value=\"info\">ข้อมูล</option><option value=\"promo\">โปรโมชั่น</option>\r\n          <option value=\"warning\">แจ้งเตือน</option><option value=\"success\">ข่าวดี</option>\r\n        </select>\r\n      </div>\r\n      <div class=\"fg\"><label><i class=\"fi fi-sr-window-popup\"></i> แสดงเป็น Popup</label>\r\n        <select class=\"fc\" id=\"ann-popup\"><option value=\"1\">ใช่</option><option value=\"0\">ไม่ใช่</option></select>\r\n      </div>\r\n      <div class=\"fg\"><label><i class=\"fi fi-sr-eye\"></i> สถานะ</label>\r\n        <select class=\"fc\" id=\"ann-active\"><option value=\"1\">เผยแพร่</option><option value=\"0\">Draft</option></select>\r\n      </div>\r\n      <div class=\"fg\"><label><i class=\"fi fi-sr-hourglass-end\"></i> วันหมดอายุ (ไม่กรอก = ไม่หมด)</label>\r\n        <input class=\"fc\" type=\"datetime-local\" id=\"ann-expires\">\r\n      </div>\r\n      <button class=\"btn-save\" onclick=\"createAnnounce()\"><i class=\"fi fi-sr-plus\"></i> เพิ่มประกาศ</button>\r\n    </div>\r\n    <div class=\"sheet-sec\">\r\n      <h3><i class=\"fi fi-sr-list\" style=\"color:var(--red);\"></i> ประกาศทั้งหมด</h3>\r\n      <div id=\"announce-list\"></div>\r\n    </div>\r\n  </div>\r\n  <div class=\"tab-content\" id=\"tc-settings\">\r\n    <div class=\"sheet-sec\">\r\n      <h3><i class=\"fi fi-sr-settings\" style=\"color:var(--red);\"></i> การตั้งค่าระบบ</h3>\r\n      <div class=\"fg\"><label><i class=\"fi fi-sr-coins\"></i> เครดิตเริ่มต้น (ผู้ใช้ใหม่)</label><input type=\"number\" class=\"fc\" id=\"st-cr\" value=\"10\" min=\"0\"></div>\r\n      <div class=\"fg\"><label><i class=\"fi fi-sr-text\"></i> ชื่อเว็บไซต์</label><input type=\"text\" class=\"fc\" id=\"st-nm\" value=\"DRINKORDOOM\"></div>\r\n      <div class=\"fg\"><label><i class=\"fi fi-sr-flask\"></i> โหมดทดสอบ</label><select class=\"fc\" id=\"st-test\"><option value=\"1\">เปิด</option><option value=\"0\">ปิด</option></select></div>\r\n      <div class=\"fg\"><label><i class=\"fi fi-sr-eye\"></i> แสดง Modal เมื่อเปิดไพ่</label><select class=\"fc\" id=\"st-modal\"><option value=\"1\">เปิด</option><option value=\"0\">ปิด</option></select></div>\r\n      <div class=\"fg\"><label><i class=\"fi fi-sr-coins\"></i> ค่าเครดิต/ใบ (default)</label><input type=\"number\" class=\"fc\" id=\"st-cost\" value=\"1\" min=\"0\"></div>\r\n      <div class=\"fg\"><label><i class=\"fi fi-sr-shopping-cart\"></i> ระบบเติมเครดิต</label><select class=\"fc\" id=\"st-topup\"><option value=\"1\">เปิด</option><option value=\"0\">ปิด</option></select></div>\r\n      <div class=\"fg\"><label><i class=\"fi fi-sr-apps\"></i> การจัดเรียงกองไพ่</label>\r\n        <select class=\"fc\" id=\"st-layout\">\r\n          <option value=\"auto\">Auto wrap (ไม่จำกัดคอลัมน์)</option>\r\n          <option value=\"2\">2 คอลัมน์</option><option value=\"3\">3 คอลัมน์</option>\r\n          <option value=\"4\">4 คอลัมน์</option><option value=\"row\">แถวนอน (scroll)</option>\r\n        </select>\r\n      </div>\r\n      <button class=\"btn-save\" onclick=\"saveSettings()\"><i class=\"fi fi-sr-disk\"></i> บันทึกการตั้งค่า</button>\r\n    </div>\r\n    <div class=\"sheet-sec\">\r\n      <h3><i class=\"fi fi-sr-coins\" style=\"color:var(--red);\"></i> แพ็กเกจเติมเครดิต</h3>\r\n      <div id=\"pkg-list\"><p style=\"color:var(--text3);font-size:.85rem;\">กำลังโหลด...</p></div>\r\n      <button class=\"btn-add\" onclick=\"openPkgForm()\"><i class=\"fi fi-sr-plus\"></i> เพิ่มแพ็กเกจ</button>\r\n    </div>\r\n  </div>\r\n  <div class=\"tab-content\" id=\"tc-search\">\r\n    <div class=\"sheet-sec\">\r\n      <h3><i class=\"fi fi-sr-search\" style=\"color:var(--red);\"></i> ค้นหาและกรองไพ่</h3>\r\n      <div style=\"display:flex;gap:10px;flex-wrap:wrap;margin-bottom:14px;\">\r\n        <div style=\"flex:1;min-width:200px;position:relative;\">\r\n          <i class=\"fi fi-sr-search\" style=\"position:absolute;left:12px;top:50%;transform:translateY(-50%);color:var(--text3);font-size:.85rem;pointer-events:none;\"></i>\r\n          <input id=\"cs-query\" type=\"text\" placeholder=\"ค้นหาข้อความในไพ่...\" oninput=\"runCardSearch()\"\r\n            style=\"width:100%;background:#151515;border:1px solid #2a2a2a;border-radius:8px;color:#fff;padding:10px 12px 10px 36px;font-family:'Kanit',sans-serif;font-size:.88rem;outline:none;\">\r\n        </div>\r\n        <select id=\"cs-deck\" onchange=\"runCardSearch()\" style=\"background:#151515;border:1px solid #2a2a2a;border-radius:8px;color:#fff;padding:10px 12px;font-family:'Kanit',sans-serif;font-size:.85rem;min-width:160px;\"><option value=\"\">ทุกกอง</option></select>\r\n        <select id=\"cs-cat\" onchange=\"runCardSearch()\" style=\"background:#151515;border:1px solid #2a2a2a;border-radius:8px;color:#fff;padding:10px 12px;font-family:'Kanit',sans-serif;font-size:.85rem;min-width:140px;\"><option value=\"\">ทุกหมวด</option></select>\r\n        <button onclick=\"toggleDupFilter()\" id=\"cs-dup-btn\" style=\"background:rgba(245,197,24,.08);border:1px solid rgba(245,197,24,.25);color:var(--gold);padding:10px 16px;border-radius:8px;cursor:pointer;font-family:'Kanit',sans-serif;font-size:.85rem;display:flex;align-items:center;gap:6px;white-space:nowrap;\">\r\n          <i class=\"fi fi-sr-copy-alt\"></i> หาคำซ้ำ\r\n        </button>\r\n      </div>\r\n      <div id=\"cs-summary\" style=\"font-size:.8rem;color:var(--text3);margin-bottom:12px;min-height:20px;\"></div>\r\n      <div id=\"cs-results\" style=\"display:flex;flex-direction:column;gap:6px;max-height:520px;overflow-y:auto;\"></div>\r\n    </div>\r\n  </div>\r\n</div>`;\r\n\r\n  /* ---- MODALS ---- */\r\n  const MODALS = `\r\n<!-- RESULT MODAL -->\r\n<div class=\"overlay\" id=\"res-overlay\">\r\n  <div class=\"res-card\">\r\n    <div class=\"res-deck-lbl\" id=\"res-dlbl\"></div>\r\n    <div class=\"res-ico-wrap\" id=\"res-ico-wrap\"><i id=\"res-ico\" class=\"fi fi-sr-flame\"></i></div>\r\n    <div class=\"res-cat\" id=\"res-cat\"></div>\r\n    <div class=\"res-txt\" id=\"res-txt\"></div>\r\n    <div class=\"res-acts\">\r\n      <button class=\"btn-close-r\" onclick=\"closeRes()\"><i class=\"fi fi-sr-cross\"></i> ปิด</button>\r\n      <button class=\"btn-next\" onclick=\"closeRes()\">ไพ่ใบต่อไป <i class=\"fi fi-sr-arrow-right\"></i></button>\r\n    </div>\r\n  </div>\r\n</div>\r\n\r\n<!-- TOP-UP MODAL -->\r\n<div class=\"overlay\" id=\"topup-overlay\">\r\n  <div class=\"modal-box topup-box\">\r\n    <button class=\"modal-x\" onclick=\"closeTopup()\"><i class=\"fi fi-sr-cross\"></i></button>\r\n    <div class=\"modal-ttl\"><i class=\"fi fi-sr-coins\" style=\"color:var(--gold);\"></i> เติม<span class=\"r\">เครดิต</span></div>\r\n    <div class=\"modal-sub\">เลือกแพ็กเกจที่ต้องการ</div>\r\n    <div class=\"topup-grid\">\r\n      <div style=\"color:var(--text3);font-size:.85rem;text-align:center;padding:32px 0;\">\r\n        <i class=\"fi fi-sr-spinner fi-spin\" style=\"font-size:1.2rem;color:var(--red);\"></i>\r\n        <div style=\"margin-top:8px;\">กำลังโหลดแพ็กเกจ...</div>\r\n      </div>\r\n    </div>\r\n    <button class=\"btn-confirm-pay\" id=\"btn-confirm-pay\" onclick=\"initiatePayment()\">\r\n      <i class=\"fi fi-sr-credit-card\"></i> ชำระเงิน\r\n    </button>\r\n  </div>\r\n</div>\r\n\r\n<!-- PACKAGE FORM MODAL -->\r\n<div class=\"form-overlay\" id=\"pkg-form-ov\">\r\n  <div class=\"form-box\">\r\n    <button class=\"form-x\" onclick=\"closePkgForm()\"><i class=\"fi fi-sr-cross\"></i></button>\r\n    <h3 id=\"pf-title\"><i class=\"fi fi-sr-coins\" style=\"color:var(--red);\"></i> เพิ่มแพ็กเกจ</h3>\r\n    <div class=\"fg\"><label><i class=\"fi fi-sr-text\"></i> ชื่อแพ็กเกจ</label><input class=\"fc\" id=\"pf-name\" placeholder=\"เช่น โปรแนะนำ\"></div>\r\n    <div class=\"fg\"><label><i class=\"fi fi-sr-coins\"></i> จำนวนเครดิต</label><input class=\"fc\" type=\"number\" id=\"pf-coins\" min=\"1\" placeholder=\"เช่น 120\"></div>\r\n    <div class=\"fg\"><label><i class=\"fi fi-sr-plus\"></i> โบนัส (0 = ไม่มี)</label><input class=\"fc\" type=\"number\" id=\"pf-bonus\" value=\"0\" min=\"0\"></div>\r\n    <div class=\"fg\"><label><i class=\"fi fi-sr-baht-sign\"></i> ราคา (บาท)</label><input class=\"fc\" type=\"number\" id=\"pf-price\" min=\"1\" placeholder=\"เช่น 99\"></div>\r\n    <div class=\"fg\"><label><i class=\"fi fi-sr-star\"></i> โปรโมชั่นแนะนำ</label><select class=\"fc\" id=\"pf-featured\"><option value=\"0\">ไม่ใช่</option><option value=\"1\">ใช่ (แสดงใหญ่)</option></select></div>\r\n    <div class=\"fg\"><label><i class=\"fi fi-sr-sort\"></i> ลำดับแสดง</label><input class=\"fc\" type=\"number\" id=\"pf-order\" value=\"0\" min=\"0\"></div>\r\n    <div class=\"fg\"><label><i class=\"fi fi-sr-eye\"></i> สถานะ</label><select class=\"fc\" id=\"pf-active\"><option value=\"1\">เปิดใช้งาน</option><option value=\"0\">ซ่อน</option></select></div>\r\n    <div class=\"form-acts\">\r\n      <button class=\"btn-cancel\" onclick=\"closePkgForm()\"><i class=\"fi fi-sr-cross\"></i> ยกเลิก</button>\r\n      <button class=\"btn-save\" onclick=\"savePkg()\"><i class=\"fi fi-sr-disk\"></i> บันทึก</button>\r\n    </div>\r\n  </div>\r\n</div>\r\n\r\n<!-- DECK FORM MODAL -->\r\n<div class=\"form-overlay\" id=\"deck-form-ov\">\r\n  <div class=\"form-box\">\r\n    <button class=\"form-x\" onclick=\"closeDeckForm()\"><i class=\"fi fi-sr-cross\"></i></button>\r\n    <h3 id=\"df-title\"><i class=\"fi fi-sr-layers\" style=\"color:var(--red);\"></i> เพิ่มกองไพ่ใหม่</h3>\r\n    <div class=\"fg\"><label><i class=\"fi fi-sr-tag\"></i> ชื่อกองไพ่</label><input class=\"fc\" id=\"df-name\" placeholder=\"เช่น ความกล้า\"></div>\r\n    <div class=\"fg\"><label><i class=\"fi fi-sr-apps\"></i> Flaticon Uicons (เช่น fi-sr-flame)</label><input class=\"fc\" id=\"df-icon\" placeholder=\"fi-sr-flame\"></div>\r\n    <div class=\"fg\">\r\n      <label><i class=\"fi fi-sr-palette\"></i> ธีมสี</label>\r\n      <div id=\"df-theme-picker\" style=\"display:flex;flex-direction:column;gap:10px;\"></div>\r\n      <input type=\"hidden\" id=\"df-theme\" value=\"fire\">\r\n    </div>\r\n    <div class=\"fg\"><label><i class=\"fi fi-sr-align-left\"></i> คำอธิบาย</label><input class=\"fc\" id=\"df-desc\" placeholder=\"คำอธิบายสั้นๆ\"></div>\r\n    <div class=\"fg\"><label><i class=\"fi fi-sr-apps-sort\"></i> หมวดหมู่</label><input class=\"fc\" id=\"df-category\" placeholder=\"เช่น เกมดื่ม, คู่รัก, ท้าทาย\"></div>\r\n    <div class=\"fg\"><label><i class=\"fi fi-sr-coins\"></i> ค่าเครดิต/ใบ</label><input class=\"fc\" type=\"number\" id=\"df-cost\" value=\"1\" min=\"0\"></div>\r\n    <div class=\"form-acts\">\r\n      <button class=\"btn-cancel\" onclick=\"closeDeckForm()\"><i class=\"fi fi-sr-cross\"></i> ยกเลิก</button>\r\n      <button class=\"btn-save\" onclick=\"saveDeck()\"><i class=\"fi fi-sr-disk\"></i> บันทึก</button>\r\n    </div>\r\n  </div>\r\n</div>\r\n\r\n<!-- LOGIN / REGISTER MODAL -->\r\n<div class=\"overlay\" id=\"login-overlay\">\r\n  <div class=\"modal-box login-box\">\r\n    <div class=\"auth-logo\">\r\n      <span class=\"logo-main\">DRINKORDOOM</span>\r\n      <span class=\"logo-sub\">ยกหรือยับ</span>\r\n    </div>\r\n    <div class=\"login-tabs\">\r\n      <button class=\"login-tab act\" id=\"lt-login\" onclick=\"switchLoginTab('login')\">เข้าสู่ระบบ</button>\r\n      <button class=\"login-tab\" id=\"lt-register\" onclick=\"switchLoginTab('register')\">สมัครสมาชิก</button>\r\n    </div>\r\n    <div id=\"lf-login\">\r\n      <div class=\"auth-ttl\"><i class=\"fi fi-sr-user\" style=\"color:var(--red);\"></i> เข้า<span class=\"r\">สู่ระบบ</span></div>\r\n      <div class=\"fg\"><label><i class=\"fi fi-sr-user\"></i> Username</label><input class=\"fc\" type=\"text\" id=\"login-username\" placeholder=\"กรอก username\" autocomplete=\"username\" oninput=\"this.value = this.value.replace(/[^a-zA-Z0-9_-]/g, '').toLowerCase()\"></div>\r\n      <div class=\"fg\"><label><i class=\"fi fi-sr-lock\"></i> Password</label>\r\n        <div style=\"position:relative;\">\r\n          <input class=\"fc\" type=\"password\" id=\"login-password\" placeholder=\"กรอกรหัสผ่าน\" autocomplete=\"current-password\" style=\"padding-right:42px;\">\r\n          <button type=\"button\" onclick=\"togglePw('login-password',this)\" style=\"position:absolute;right:12px;top:50%;transform:translateY(-50%);background:none;border:none;cursor:pointer;color:var(--text3);font-size:1rem;padding:0;\"><i class=\"fi fi-sr-eye\"></i></button>\r\n        </div>\r\n      </div>\r\n      <div class=\"login-err\" id=\"login-err\"></div>\r\n      <button class=\"btn-auth\" id=\"btn-do-login\" onclick=\"doLogin()\"><i class=\"fi fi-sr-sign-in-alt\"></i> เข้าสู่ระบบ</button>\r\n    </div>\r\n    <div id=\"lf-register\" style=\"display:none\">\r\n      <div class=\"auth-ttl\"><i class=\"fi fi-sr-user-add\" style=\"color:var(--red);\"></i> สมัคร<span class=\"r\">สมาชิก</span></div>\r\n      <div class=\"fg\"><label><i class=\"fi fi-sr-user\"></i> Username</label><input class=\"fc\" type=\"text\" id=\"reg-username\" placeholder=\"ตั้ง username (อย่างน้อย 3 ตัว)\" autocomplete=\"username\" oninput=\"this.value = this.value.replace(/[^a-zA-Z0-9_-]/g, '').toLowerCase()\"></div>\r\n      <div class=\"fg\"><label><i class=\"fi fi-sr-lock\"></i> Password</label>\r\n        <div style=\"position:relative;\">\r\n          <input class=\"fc\" type=\"password\" id=\"reg-password\" placeholder=\"ตั้งรหัสผ่าน (อย่างน้อย 6 ตัว)\" autocomplete=\"new-password\" style=\"padding-right:42px;\">\r\n          <button type=\"button\" onclick=\"togglePw('reg-password',this)\" style=\"position:absolute;right:12px;top:50%;transform:translateY(-50%);background:none;border:none;cursor:pointer;color:var(--text3);font-size:1rem;padding:0;\"><i class=\"fi fi-sr-eye\"></i></button>\r\n        </div>\r\n      </div>\r\n      <div class=\"fg\"><label><i class=\"fi fi-sr-lock\"></i> ยืนยัน Password</label>\r\n        <div style=\"position:relative;\">\r\n          <input class=\"fc\" type=\"password\" id=\"reg-confirm\" placeholder=\"พิมพ์รหัสผ่านอีกครั้ง\" autocomplete=\"new-password\" style=\"padding-right:42px;\">\r\n          <button type=\"button\" onclick=\"togglePw('reg-confirm',this)\" style=\"position:absolute;right:12px;top:50%;transform:translateY(-50%);background:none;border:none;cursor:pointer;color:var(--text3);font-size:1rem;padding:0;\"><i class=\"fi fi-sr-eye\"></i></button>\r\n        </div>\r\n      </div>\r\n      <div class=\"login-err\" id=\"reg-err\"></div>\r\n      <button class=\"btn-auth\" id=\"btn-do-register\" onclick=\"doRegister()\"><i class=\"fi fi-sr-user-add\"></i> สมัครสมาชิก</button>\r\n    </div>\r\n  </div>\r\n</div>`;\r\n\r\n  /* ---- OVERLAYS & MISC ---- */\r\n  const OVERLAYS = `\r\n<!-- TOUCH PICKER -->\r\n<div id=\"touch-picker-ov\" style=\"display:none;\">\r\n  <div id=\"touch-area\">\r\n    <div id=\"touch-instruction\">\r\n      <i class=\"fi fi-sr-cursor-finger\"></i>\r\n      <span id=\"touch-msg\">วางนิ้ว 2-6 คนพร้อมกันบนหน้าจอ</span>\r\n    </div>\r\n    <div id=\"touch-countdown\" style=\"display:none;\"></div>\r\n    <div id=\"touch-dots-wrap\"></div>\r\n    <button id=\"touch-close-btn\" onclick=\"closeTouchPicker()\">\r\n      <i class=\"fi fi-sr-cross\"></i> ยกเลิก\r\n    </button>\r\n  </div>\r\n</div>\r\n\r\n<!-- TOAST -->\r\n<div class=\"toast\" id=\"toast\">\r\n  <i id=\"toast-ico\" class=\"fi fi-sr-check-circle\" style=\"color:#4caf50;\"></i>\r\n  <span id=\"toast-msg\"></span>\r\n</div>\r\n\r\n<!-- PROFILE -->\r\n<div id=\"profile-overlay\">\r\n  <div class=\"pf-box\">\r\n    <div class=\"pf-top-bar\"></div>\r\n    <button class=\"pf-close\" onclick=\"closeProfile()\">✕</button>\r\n    <div class=\"pf-header\">\r\n      <div class=\"pf-identity\">\r\n        <div class=\"pf-avatar\"><i class=\"fi fi-sr-user\"></i></div>\r\n        <div>\r\n          <div id=\"pf-username\" class=\"pf-name\"></div>\r\n          <div class=\"pf-status\">\r\n            <div class=\"pf-status-dot\"></div>\r\n            <span class=\"pf-status-label\">ออนไลน์</span>\r\n          </div>\r\n        </div>\r\n      </div>\r\n      <div class=\"pf-credit-box\">\r\n        <div>\r\n          <div class=\"pf-credit-label\">เครดิตคงเหลือ</div>\r\n          <div id=\"pf-credits\" class=\"pf-credit-amount\"></div>\r\n        </div>\r\n        <button class=\"pf-topup-btn\" onclick=\"closeProfile(); openTopup();\">+ เติมเครดิต</button>\r\n      </div>\r\n    </div>\r\n    <div class=\"pf-history-wrap\">\r\n      <div class=\"pf-section-title\">\r\n        <div class=\"pf-section-bar\"></div>\r\n        <span class=\"pf-section-label\">ประวัติเครดิต</span>\r\n      </div>\r\n      <div id=\"pf-history\" class=\"pf-history-list\"></div>\r\n    </div>\r\n    <div class=\"pf-footer\">\r\n      <div class=\"pf-uid-box\">\r\n        <span class=\"pf-uid-label\">รหัสสมาชิก</span>\r\n        <span id=\"pf-uid\" class=\"pf-uid-value\"></span>\r\n      </div>\r\n    </div>\r\n  </div>\r\n</div>`;\r\n\r\n  /* ---- INJECT ---- */\r\n  const app = document.getElementById('app');\r\n  if (!app) { console.error('ui.js: #app not found'); return; }\r\n\r\n  app.innerHTML = HEADER + HOME + GAME + ADMIN + MODALS + OVERLAYS;\r\n\r\n})();"
        }
    ]
}