            "name": "Commit-0",
            "content": "<!DOCTYPE html>\r\n<html lang=\"th\">\r\n<head>\r\n<meta charset=\"UTF-8\">\r\n<meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\r\n<title>DEALSHOT — ไพ่วงเหล้า</title>\r\n\r\n<!-- Fonts -->\r\n<link href=\"https://fonts.googleapis.com/css2?family=Kanit:ital,wght@0,300;0,400;0,600;0,700;0,800;0,900;1,400&display=swap\" rel=\"stylesheet\">\r\n\r\n<!-- Flaticon Uicons -->\r\n<link rel=\"stylesheet\" href=\"https://cdn-uicons.flaticon.com/2.6.0/uicons-solid-rounded/css/uicons-solid-rounded.css\">\r\n<link rel=\"stylesheet\" href=\"https://cdn-uicons.flaticon.com/2.6.0/uicons-regular-rounded/css/uicons-regular-rounded.css\">\r\n<link rel=\"stylesheet\" href=\"https://cdn-uicons.flaticon.com/2.6.0/uicons-brands/css/uicons-brands.css\">\r\n\r\n<!-- Styles -->\r\n<link rel=\"stylesheet\" href=\"css/main.css\">\r\n<link rel=\"stylesheet\" href=\"css/components.css\">\r\n<link rel=\"stylesheet\" href=\"css/admin.css\">\r\n</head>\r\n<body>\r\n\r\n<!-- ============ HEADER ============ -->\r\n<header class=\"hdr\">\r\n  <div class=\"logo\" onclick=\"goHome()\">\r\n    <div class=\"logo-wordmark\">\r\n      <span class=\"logo-main\">DRINKORDOOM</span>\r\n      <span class=\"logo-sub\">ยกหรือยับ</span>\r\n    </div>\r\n  </div>\r\n  <div class=\"hdr-r\">\r\n    <div class=\"credit-pill\" onclick=\"openTopup()\">\r\n      <i class=\"fi fi-sr-coins\" style=\"color:var(--gold);font-size:.95rem;\"></i>\r\n      <span class=\"amt\" id=\"cr-disp\">0</span>\r\n      <span class=\"lbl\">เครดิต</span>\r\n    </div>\r\n    <button class=\"btn-topup\" onclick=\"openTopup()\">\r\n      <i class=\"fi fi-sr-plus\"></i><span class=\"lbl-txt\">เติมเครดิต</span>\r\n    </button>\r\n      <button class=\"btn-ghost\" onclick=\"showAdmin()\">\r\n        <i class=\"fi fi-sr-tools\"></i>\r\n      </button>\r\n  </div>\r\n</header>\r\n\r\n<!-- ============ HOME SCREEN ============ -->\r\n<div id=\"home-screen\">\r\n  <section class=\"hero\">\r\n    <div class=\"big-title\"><div>Drink or Doom</div><div class=\"r\">ยกหรือยับ</div></div>\r\n    <p class=\"hero-sub\">\r\n      <span class=\"chip\"><i class=\"fi fi-sr-layers\" style=\"color:var(--red);font-size:.85rem;\"></i> เลือกกองไพ่</span>\r\n      <span class=\"sep\">·</span>\r\n      <span class=\"chip\"><i class=\"fi fi-sr-coins\" style=\"color:var(--gold);font-size:.85rem;\"></i> จ่ายเครดิต</span>\r\n      <span class=\"sep\">·</span>\r\n      <span class=\"chip\"><i class=\"fi fi-sr-bolt\" style=\"color:var(--red);font-size:.85rem;\"></i> รับชะตากรรม</span>\r\n    </p>\r\n    <p class=\"sec-label\">เลือกกองไพ่</p>\r\n    <div class=\"deck-grid-wrap\">\r\n      <div class=\"deck-grid\" id=\"deck-grid\"></div>\r\n      <button class=\"btn-play\" id=\"btn-play\" onclick=\"startGame()\" disabled>\r\n        <i class=\"fi fi-sr-play\"></i> เริ่มเล่น\r\n      </button>\r\n    </div>\r\n  </section>\r\n</div>\r\n\r\n<!-- ============ GAME SCREEN ============ -->\r\n<div id=\"game-screen\">\r\n  <div class=\"game-hdr\">\r\n    <div style=\"display:flex;align-items:center;gap:14px;\">\r\n      <button class=\"btn-ghost\" onclick=\"goHome()\"><i class=\"fi fi-sr-angle-left\"></i> กลับ</button>\r\n      <div class=\"g-deck-info\">\r\n        <div class=\"g-deck-ico\" id=\"g-ico-wrap\"><i id=\"g-ico\" class=\"fi fi-sr-flame\"></i></div>\r\n        <div>\r\n          <div class=\"g-nm\" id=\"g-nm\"></div>\r\n          <div class=\"g-rm\"><i class=\"fi fi-rr-copy\" style=\"font-size:.7rem;opacity:.5;\"></i><span id=\"g-rm\"></span></div>\r\n        </div>\r\n      </div>\r\n    </div>\r\n    <div style=\"display:flex;align-items:center;gap:10px;\">\r\n      <!-- โหมด toggle -->\r\n      <div class=\"layout-toggle\">\r\n        <button class=\"lt-btn act\" id=\"lt-scatter\" onclick=\"setLayout('scatter')\" title=\"กระจายเละ\">\r\n          <i class=\"fi fi-sr-shuffle\"></i>\r\n        </button>\r\n        <button class=\"lt-btn\" id=\"lt-stack\" onclick=\"setLayout('stack')\" title=\"เรียงตับ\">\r\n          <i class=\"fi fi-sr-layers\"></i>\r\n        </button>\r\n      </div>\r\n      <div class=\"g-credit\"><i class=\"fi fi-sr-coins\"></i> <span id=\"g-cr\">0</span> เครดิต</div>\r\n    </div>\r\n  </div>\r\n  <div class=\"table-area\">\r\n    <div class=\"cards-wrap\" id=\"cards-wrap\"></div>\r\n    <div class=\"cost-hint\">\r\n      <i class=\"fi fi-rr-cursor\" style=\"opacity:.6;\"></i>\r\n      แตะการ์ดเพื่อเปิด · ใช้ <span class=\"hl\" id=\"cost-show\">1</span> เครดิต/ใบ\r\n    </div>\r\n  </div>\r\n</div>\r\n\r\n<!-- ============ ADMIN SCREEN ============ -->\r\n<div id=\"admin-screen\">\r\n  <div class=\"adm-hdr\">\r\n    <div>\r\n      <div class=\"adm-ttl\"><i class=\"fi fi-sr-settings-sliders\" style=\"color:var(--red);\"></i> <span class=\"r\">ADMIN</span> PANEL</div>\r\n      <div class=\"adm-sub\">จัดการไพ่และกองไพ่ทั้งหมด</div>\r\n    </div>\r\n    <button class=\"btn-ghost\" onclick=\"goHome()\"><i class=\"fi fi-sr-home\"></i> หน้าหลัก</button>\r\n  </div>\r\n  <div class=\"tabs\">\r\n    <button class=\"tab act\" onclick=\"switchTab('decks',0)\"><i class=\"fi fi-sr-layers\"></i> กองไพ่</button>\r\n    <button class=\"tab\" onclick=\"switchTab('cards',1)\"><i class=\"fi fi-sr-pencil\"></i> แก้ไขไพ่</button>\r\n    <button class=\"tab\" onclick=\"switchTab('settings',2)\"><i class=\"fi fi-sr-settings\"></i> ตั้งค่า</button>\r\n    <button class=\"tab\" onclick=\"switchTab('sheet',3)\"><i class=\"fi fi-sr-table\"></i> Spreadsheet</button>\r\n  </div>\r\n\r\n  <!-- Tab: Decks -->\r\n  <div class=\"tab-content act\" id=\"tc-decks\">\r\n    <div class=\"deck-list-adm\" id=\"adm-deck-list\"></div>\r\n    <button class=\"btn-add\" onclick=\"openDeckForm()\"><i class=\"fi fi-sr-plus\"></i> เพิ่มกองไพ่ใหม่</button>\r\n  </div>\r\n\r\n  <!-- Tab: Cards -->\r\n  <div class=\"tab-content\" id=\"tc-cards\">\r\n    <div style=\"display:flex;align-items:center;gap:10px;margin-bottom:16px;\">\r\n      <label style=\"color:var(--text2);font-size:.85rem;display:flex;align-items:center;gap:6px;\">\r\n        <i class=\"fi fi-sr-layers\"></i> กองไพ่:\r\n      </label>\r\n      <select class=\"fc\" id=\"adm-deck-sel\" style=\"width:200px\" onchange=\"loadCE()\"></select>\r\n    </div>\r\n    <div class=\"card-editor-box\">\r\n      <h3 id=\"ce-title\"><i class=\"fi fi-sr-layers\" style=\"color:var(--red);\"></i> เลือกกองไพ่ก่อน</h3>\r\n      <div class=\"card-list-ed\" id=\"card-list-ed\"></div>\r\n      <button class=\"btn-add-card\" onclick=\"addCRow()\"><i class=\"fi fi-sr-plus\"></i> เพิ่มไพ่</button>\r\n    </div>\r\n    <div style=\"display:flex;justify-content:flex-end;margin-top:14px;\">\r\n      <button class=\"btn-save\" onclick=\"saveCards()\"><i class=\"fi fi-sr-disk\"></i> บันทึก</button>\r\n    </div>\r\n  </div>\r\n\r\n  <!-- Tab: Settings -->\r\n  <div class=\"tab-content\" id=\"tc-settings\">\r\n    <div class=\"sheet-sec\">\r\n      <h3><i class=\"fi fi-sr-settings\" style=\"color:var(--red);\"></i> ตั้งค่าระบบ</h3>\r\n      <p>กำหนดเครดิตเริ่มต้นและชื่อเว็บ</p>\r\n      <div class=\"fg\"><label><i class=\"fi fi-sr-coins\"></i> เครดิตเริ่มต้น (ทดสอบ)</label><input type=\"number\" class=\"fc\" id=\"st-cr\" value=\"10\"></div>\r\n      <div class=\"fg\"><label><i class=\"fi fi-sr-tag\"></i> ชื่อเว็บ</label><input type=\"text\" class=\"fc\" id=\"st-nm\" value=\"DEALSHOT\"></div>\r\n      <div class=\"fg\">\r\n        <label><i class=\"fi fi-sr-flask\"></i> โหมดทดสอบ</label>\r\n        <select class=\"fc\" id=\"st-test\"><option value=\"1\">เปิด</option><option value=\"0\">ปิด</option></select>\r\n      </div>\r\n      <button class=\"btn-save\" onclick=\"saveSettings()\"><i class=\"fi fi-sr-disk\"></i> บันทึก</button>\r\n    </div>\r\n  </div>\r\n\r\n  <!-- Tab: Spreadsheet -->\r\n  <div class=\"tab-content\" id=\"tc-sheet\">\r\n    <div class=\"sheet-sec\">\r\n      <h3><i class=\"fi fi-brands-google\" style=\"color:var(--red);\"></i> เชื่อม Google Spreadsheet</h3>\r\n      <p>ใส่ URL ของ Google Sheets (Share → Anyone with link can view)</p>\r\n      <div class=\"sheet-row\">\r\n        <input type=\"text\" class=\"sh-inp\" id=\"sheet-url\" placeholder=\"https://docs.google.com/spreadsheets/d/...\">\r\n        <button class=\"btn-conn\" onclick=\"connectSheet()\"><i class=\"fi fi-sr-link\"></i> เชื่อมต่อ</button>\r\n      </div>\r\n      <div style=\"margin-top:16px;padding:14px;background:#1a1a1a;border-radius:8px;font-size:.8rem;color:var(--text2);line-height:2;\">\r\n        <strong style=\"color:#fff;display:flex;align-items:center;gap:6px;margin-bottom:4px;\">\r\n          <i class=\"fi fi-sr-info\" style=\"color:var(--red);\"></i> รูปแบบ Sheet ที่รองรับ:\r\n        </strong>\r\n        Sheet 1: <code style=\"color:var(--gold);\">decks</code> — id | name | icon | theme | cost_per_card | description<br>\r\n        Sheet 2: <code style=\"color:var(--gold);\">cards</code> — deck_id | category | text\r\n      </div>\r\n    </div>\r\n    <div class=\"sheet-sec\">\r\n      <h3><i class=\"fi fi-sr-database\" style=\"color:var(--red);\"></i> Export / Import</h3>\r\n      <p>สำรองหรือนำเข้าข้อมูลไพ่ทั้งหมด</p>\r\n      <div style=\"display:flex;gap:10px;flex-wrap:wrap;\">\r\n        <button class=\"btn-conn\" onclick=\"exportData()\"><i class=\"fi fi-sr-download\"></i> Export JSON</button>\r\n        <button class=\"btn-conn ghost\" onclick=\"importData()\"><i class=\"fi fi-sr-upload\"></i> Import JSON</button>\r\n        <button class=\"btn-conn ghost\" onclick=\"resetData()\"><i class=\"fi fi-sr-rotate-left\"></i> รีเซ็ต</button>\r\n      </div>\r\n      <input type=\"file\" id=\"imp-file\" accept=\".json\" style=\"display:none\" onchange=\"handleImport(event)\">\r\n    </div>\r\n  </div>\r\n</div>\r\n\r\n<!-- ============ RESULT MODAL ============ -->\r\n<div class=\"overlay\" id=\"res-overlay\">\r\n  <div class=\"res-card\">\r\n    <div class=\"res-deck-lbl\" id=\"res-dlbl\"></div>\r\n    <div class=\"res-ico-wrap\" id=\"res-ico-wrap\"><i id=\"res-ico\" class=\"fi fi-sr-flame\"></i></div>\r\n    <div class=\"res-cat\" id=\"res-cat\"></div>\r\n    <div class=\"res-txt\" id=\"res-txt\"></div>\r\n    <div class=\"res-acts\">\r\n      <button class=\"btn-close-r\" onclick=\"closeRes()\"><i class=\"fi fi-sr-cross\"></i> ปิด</button>\r\n      <button class=\"btn-next\" onclick=\"closeRes()\">ไพ่ใบต่อไป <i class=\"fi fi-sr-arrow-right\"></i></button>\r\n    </div>\r\n  </div>\r\n</div>\r\n\r\n<!-- ============ TOP-UP MODAL ============ -->\r\n<div class=\"overlay\" id=\"topup-overlay\">\r\n  <div class=\"modal-box\">\r\n    <button class=\"modal-x\" onclick=\"closeTopup()\"><i class=\"fi fi-sr-cross\"></i></button>\r\n    <div class=\"modal-ttl\"><i class=\"fi fi-sr-coins\" style=\"color:var(--gold);\"></i> เติม<span class=\"r\">เครดิต</span></div>\r\n    <div class=\"modal-sub\">เลือกแพ็กเกจที่ต้องการ</div>\r\n    <div class=\"topup-grid\">\r\n      <div class=\"topup-opt\" onclick=\"selPkg(this,10)\">\r\n        <div class=\"coins\"><i class=\"fi fi-sr-coins\"></i> 10</div><div class=\"price\">฿29</div>\r\n      </div>\r\n      <div class=\"topup-opt\" onclick=\"selPkg(this,30)\">\r\n        <div class=\"coins\"><i class=\"fi fi-sr-coins\"></i> 30</div><div class=\"price\">฿79</div>\r\n        <div class=\"bonus\"><i class=\"fi fi-sr-plus\"></i> +5 โบนัส</div>\r\n      </div>\r\n      <div class=\"topup-opt\" onclick=\"selPkg(this,60)\">\r\n        <div class=\"coins\"><i class=\"fi fi-sr-coins\"></i> 60</div><div class=\"price\">฿149</div>\r\n        <div class=\"bonus\"><i class=\"fi fi-sr-plus\"></i> +15 โบนัส</div>\r\n      </div>\r\n      <div class=\"topup-opt\" onclick=\"selPkg(this,150)\">\r\n        <div class=\"coins\"><i class=\"fi fi-sr-coins\"></i> 150</div><div class=\"price\">฿349</div>\r\n        <div class=\"bonus\"><i class=\"fi fi-sr-star\"></i> +50 โบนัส</div>\r\n      </div>\r\n    </div>\r\n    <div class=\"coming-banner\">\r\n      <strong><i class=\"fi fi-sr-triangle-warning\"></i> ระบบชำระเงินกำลังพัฒนา</strong>\r\n      <span style=\"font-size:.75rem;\">กด \"รับฟรี\" ด้านล่างเพื่อทดสอบ</span>\r\n    </div>\r\n    <button class=\"btn-free\" onclick=\"freeCredit()\"><i class=\"fi fi-sr-gift\"></i> รับฟรี 10 เครดิต (ทดสอบ)</button>\r\n  </div>\r\n</div>\r\n\r\n<!-- ============ DECK FORM MODAL ============ -->\r\n<div class=\"form-overlay\" id=\"deck-form-ov\">\r\n  <div class=\"form-box\">\r\n    <button class=\"form-x\" onclick=\"closeDeckForm()\"><i class=\"fi fi-sr-cross\"></i></button>\r\n    <h3 id=\"df-title\"><i class=\"fi fi-sr-layers\" style=\"color:var(--red);\"></i> เพิ่มกองไพ่ใหม่</h3>\r\n    <div class=\"fg\"><label><i class=\"fi fi-sr-tag\"></i> ชื่อกองไพ่</label><input class=\"fc\" id=\"df-name\" placeholder=\"เช่น ความกล้า\"></div>\r\n    <div class=\"fg\">\r\n      <label><i class=\"fi fi-sr-apps\"></i> Flaticon Uicons (เช่น fi-sr-flame)</label>\r\n      <input class=\"fc\" id=\"df-icon\" placeholder=\"fi-sr-flame\">\r\n    </div>\r\n    <div class=\"fg\">\r\n      <label><i class=\"fi fi-sr-palette\"></i> ธีมสี</label>\r\n      <select class=\"fc\" id=\"df-theme\">\r\n        <option value=\"fire\">ไฟ — แดง</option>\r\n        <option value=\"magic\">เวทมนตร์ — ม่วง</option>\r\n        <option value=\"skull\">กะโหลก — แดงเข้ม</option>\r\n        <option value=\"heart\">หัวใจ — ชมพู</option>\r\n        <option value=\"star\">ดาว — ทอง</option>\r\n        <option value=\"bolt\">ฟ้าผ่า — ส้ม</option>\r\n        <option value=\"default\">ค่าเริ่มต้น — เทา</option>\r\n      </select>\r\n    </div>\r\n    <div class=\"fg\"><label><i class=\"fi fi-sr-align-left\"></i> คำอธิบาย</label><input class=\"fc\" id=\"df-desc\" placeholder=\"คำอธิบายสั้นๆ\"></div>\r\n    <div class=\"fg\"><label><i class=\"fi fi-sr-coins\"></i> ค่าเครดิต/ใบ</label><input class=\"fc\" type=\"number\" id=\"df-cost\" value=\"1\" min=\"0\"></div>\r\n    <div class=\"form-acts\">\r\n      <button class=\"btn-cancel\" onclick=\"closeDeckForm()\"><i class=\"fi fi-sr-cross\"></i> ยกเลิก</button>\r\n      <button class=\"btn-save\" onclick=\"saveDeck()\"><i class=\"fi fi-sr-disk\"></i> บันทึก</button>\r\n    </div>\r\n  </div>\r\n</div>\r\n\r\n<!-- ============ TOAST ============ -->\r\n<div class=\"toast\" id=\"toast\">\r\n  <i id=\"toast-ico\" class=\"fi fi-sr-check-circle\" style=\"color:#4caf50;\"></i>\r\n  <span id=\"toast-msg\"></span>\r\n</div>\r\n\r\n<!-- ============ SCRIPTS ============ -->\r\n<!-- โหลด db.js ก่อน เพราะไฟล์อื่นใช้ DB -->\r\n<script src=\"js/db.js\"></script>\r\n<script src=\"js/admin-keys.js\"></script>\r\n<script src=\"js/payment.js\"></script>\r\n<script src=\"js/api.js\"></script>\r\n<script src=\"js/components.js\"></script>\r\n<script src=\"js/admin.js\"></script>\r\n<script src=\"js/app.js\"></script>\r\n</body>\r\n</html>\r\n\r\n<div class=\"coming-banner\" id=\"test-banner\">\r\n  <strong><i class=\"fi fi-sr-triangle-warning\"></i> ระบบชำระเงินกำลังพัฒนา</strong>\r\n  <span style=\"font-size:.75rem;\">กด \"รับฟรี\" ด้านล่างเพื่อทดสอบ</span>\r\n</div>\r\n<button class=\"btn-free\" id=\"test-btn\" onclick=\"freeCredit()\"><i class=\"fi fi-sr-gift\"></i> รับฟรี 10 เครดิต (ทดสอบ)</button>"
        }
    ]
}